# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=recall
POSTGRES_USER=recall
POSTGRES_PASSWORD=changeme_local
DATABASE_URL=postgresql+asyncpg://recall:changeme_local@postgres:5432/recall
DATABASE_SYNC_URL=postgresql://recall:changeme_local@postgres:5432/recall

# ── Redis / Celery ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Storage ────────────────────────────────────────────────────────────────
MEDIA_ROOT=/data/media
STORAGE_BACKEND=local

# ── MinIO (only needed if STORAGE_BACKEND=minio) ───────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=recall

# ── Transcription ──────────────────────────────────────────────────────────
# Options: tiny | base | small | medium | large-v3
# tiny/base  → fast, lower accuracy, runs on any machine
# small      → good balance for most use cases
# medium+    → best accuracy, needs 5+ GB RAM
WHISPER_MODEL=base
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# ── Diarization (speaker identification) ──────────────────────────────────
# Requires: accepting model at https://huggingface.co/pyannote/speaker-diarization-3.1
# and uncommenting pyannote in requirements.txt
USE_DIARIZATION=false
HUGGINGFACE_TOKEN=

# ── Voice profiles (recognize speakers across meetings) ────────────────────
# Requires diarization + accepting https://huggingface.co/pyannote/embedding
# (same HUGGINGFACE_TOKEN). VOICE_MATCH_THRESHOLD is a cosine similarity in
# [0,1]; higher = stricter auto-labeling. Also tunable from the admin UI.
VOICE_EMBED_MODEL=pyannote/embedding
VOICE_MATCH_THRESHOLD=0.75

# ── Auth ───────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Authentication mode:
#   local → built-in email/password login (default)
#   proxy → trust forward-auth identity headers from an upstream proxy such as
#           Authentik (Proxy Provider) behind Traefik's forwardAuth middleware.
#           The app does no login of its own; users are created just-in-time
#           from the headers below.
#
# ⚠️  Only enable proxy mode when the app is reachable EXCLUSIVELY through the
#     authenticating proxy. The api must never be exposed directly (it isn't in
#     docker-compose.prod.yml), and the Authentik forwardAuth middleware must
#     list these headers in `authResponseHeaders` so a client cannot spoof them.
AUTH_MODE=local

# Header names the proxy injects (Authentik defaults shown; case-insensitive).
PROXY_AUTH_EMAIL_HEADER=X-Authentik-Email
PROXY_AUTH_NAME_HEADER=X-Authentik-Name
PROXY_AUTH_GROUPS_HEADER=X-Authentik-Groups
# Users in this Authentik group become app admins. Leave blank to make every
# proxy-authenticated user an admin.
PROXY_AUTH_ADMIN_GROUP=
# Where the UI "Sign out" link sends users in proxy mode.
PROXY_AUTH_LOGOUT_URL=/outpost.goauthentik.io/sign_out

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# For production, set this to your actual domain(s).
CORS_ORIGINS=https://your.domain.com

# ── Upload ─────────────────────────────────────────────────────────────────
# Maximum upload size in bytes. Default: 2 GB.
MAX_UPLOAD_BYTES=2147483648

# ── Summarization (Ollama) ─────────────────────────────────────────────────
# Meeting summaries are generated by an Ollama LLM. Pick one:
#
#   A) Bundled — run the optional `ollama` service shipped in the compose file.
#      Enable it via COMPOSE_PROFILES below, then pull the model once:
#        docker exec recall_ollama ollama pull llama3.1:8b
#      Keep OLLAMA_BASE_URL=http://ollama:11434.
#
#   B) Your own — point OLLAMA_BASE_URL at an Ollama you already run
#      (e.g. http://192.168.1.50:11434) and leave "ollama" out of the profile.
#
# COMPOSE_PROFILES turns on optional services. Include "ollama" to run the
# bundled LLM; combine others comma-separated, e.g. ollama,minio,monitor.
# Leave blank to use an external Ollama (option B) or skip summaries entirely.
COMPOSE_PROFILES=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
# Embedding model for transcript chat (RAG). Pull it once:
#   docker exec recall_ollama ollama pull nomic-embed-text
# If you change this, re-index meetings (the embedding dimension must stay 768
# unless you also update the migration/model).
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Retention (automatic cleanup of old recordings) ────────────────────────
# A daily `beat` job removes recordings older than RETENTION_DAYS. Pinned
# ("Kept") meetings are always exempt. Also configurable from the admin UI.
#   off        → never auto-delete (default)
#   audio_only → delete the media file, keep transcript/notes/summary
#   all        → delete the entire meeting and its data
RETENTION_MODE=off
# Age threshold in days. 0 disables retention regardless of mode.
RETENTION_DAYS=0

# ── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
