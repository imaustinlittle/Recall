# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=recall
POSTGRES_USER=recall
POSTGRES_PASSWORD=changeme_local
DATABASE_URL=postgresql+asyncpg://recall:changeme_local@postgres:5432/recall
DATABASE_SYNC_URL=postgresql://recall:changeme_local@postgres:5432/recall

# ── Redis / Celery ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Storage ────────────────────────────────────────────────────────────────
MEDIA_ROOT=/data/media
STORAGE_BACKEND=local

# ── MinIO (only needed if STORAGE_BACKEND=minio) ───────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=recall

# ── Transcription ──────────────────────────────────────────────────────────
# Options: tiny | base | small | medium | large-v3
# tiny/base  → fast, lower accuracy, runs on any machine
# small      → good balance for most use cases
# medium+    → best accuracy, needs 5+ GB RAM
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Diarization (speaker identification) ──────────────────────────────────
# Requires: accepting model at https://huggingface.co/pyannote/speaker-diarization-3.1
# and uncommenting pyannote in requirements.txt
USE_DIARIZATION=false
HUGGINGFACE_TOKEN=

# ── Auth ───────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# For production, set this to your actual domain(s).
CORS_ORIGINS=http://localhost:3000

# ── Upload ─────────────────────────────────────────────────────────────────
# Maximum upload size in bytes. Default: 2 GB.
MAX_UPLOAD_BYTES=2147483648

# ── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
